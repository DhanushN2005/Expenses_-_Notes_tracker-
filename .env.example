# ==============================================================================
# NOTED. PRODUCTIVITY WORKSPACE APP - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to '.env' or 'backend/.env' and customize as needed.
# Do not commit your real '.env' file containing secrets to version control.

# 1. MONGODB DATABASE CONFIGURATION
# Set your MongoDB connection URI (Atlas cloud cluster or local database)
# Default: mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017

# 2. JWT SECURITY KEY
# Change this to a secure, randomly generated string in production
# Default: super_secret_notes_jwt_key_that_is_long_and_secure
JWT_SECRET=super_secret_notes_jwt_key_that_is_long_and_secure

# 3. BACKEND API SERVER PORT
# Port for the Go Gin API server to listen on
# Default: 8081
PORT=8081

# 4. CORS ORIGIN ACCESS POLICY
# Frontend URL permitted to make network requests to this API
# Default: http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
